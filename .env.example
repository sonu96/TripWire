# TripWire Configuration
APP_ENV=development
APP_PORT=3402

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Svix (Webhook Delivery)
SVIX_API_KEY=your_svix_api_key
SVIX_SIGNING_SECRET=whsec_your_signing_secret

# Goldsky
GOLDSKY_API_KEY=your_goldsky_api_key
GOLDSKY_PROJECT_ID=your_project_id
GOLDSKY_WEBHOOK_SECRET=

# Blockchain RPC (for finality checks via httpx)
BASE_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ERC-8004 Registry (mainnet since Jan 29 2026)
ERC8004_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# USDC Contract Addresses
USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ETHEREUM=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_ARBITRUM=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
