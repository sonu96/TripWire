# ============================================================
# TripWire — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── App Config ──────────────────────────────────────────────
APP_ENV=development                          # development | production
APP_PORT=3402                                # HTTP port for the FastAPI server
APP_BASE_URL=http://localhost:3402           # Public base URL (used in webhook callbacks)
LOG_LEVEL=info                               # debug | info | warning | error
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3402"]  # JSON array of allowed origins

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key              # Public anon key (safe to expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # SECRET — bypasses RLS; never expose

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379             # Used for SIWE nonce storage & rate limiting

# ── Convoy / Webhooks ──────────────────────────────────────
CONVOY_API_KEY=your_convoy_api_key           # SECRET — Convoy project API key
CONVOY_URL=http://localhost:5005             # Convoy self-hosted base URL
WEBHOOK_SIGNING_SECRET=your_signing_secret   # SECRET — default HMAC secret for webhook payloads

# ── Goldsky ─────────────────────────────────────────────────
GOLDSKY_API_KEY=your_goldsky_api_key         # SECRET — Goldsky Mirror API key
GOLDSKY_PROJECT_ID=your_project_id           # Goldsky project identifier
GOLDSKY_WEBHOOK_SECRET=your_goldsky_webhook_secret  # SECRET — validates inbound Goldsky webhooks

# ── x402 Payment ────────────────────────────────────────────
TRIPWIRE_TREASURY_ADDRESS=0xYourTreasuryAddress  # Wallet that receives USDC registration payments
X402_FACILITATOR_URL=https://x402.org/facilitator  # x402 facilitator endpoint
X402_REGISTRATION_PRICE=$1.00                # Price charged to register an endpoint via x402
X402_NETWORK=eip155:8453                     # CAIP-2 chain ID (Base mainnet)

# ── SIWE Auth ───────────────────────────────────────────────
SIWE_DOMAIN=tripwire.dev                     # Domain for Sign-In with Ethereum messages
AUTH_TIMESTAMP_TOLERANCE_SECONDS=300          # Max age (seconds) of a SIWE signature

# ── ERC-8004 Identity ──────────────────────────────────────
# CREATE2-deployed registries — same address on all EVM chains
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
IDENTITY_CACHE_TTL=300                       # Seconds to cache identity lookups

# ── Facilitator ─────────────────────────────────────────────
FACILITATOR_WEBHOOK_SECRET=your_facilitator_secret  # SECRET — validates x402 facilitator callbacks

# ── Blockchain RPC (Goldsky Edge endpoints) ──────────────────
BASE_RPC_URL=                                # Goldsky Edge endpoint for Base
ETHEREUM_RPC_URL=                            # Goldsky Edge endpoint for Ethereum
ARBITRUM_RPC_URL=                            # Goldsky Edge endpoint for Arbitrum
GOLDSKY_EDGE_API_KEY=                        # SECRET — Goldsky Edge API key for authenticated RPC

# ── Feature Flags ───────────────────────────────────────────
DLQ_ENABLED=true                             # Enable dead-letter queue processing
FINALITY_POLLER_ENABLED=true                 # Enable on-chain finality polling

# ── Dead Letter Queue ──────────────────────────────────────
DLQ_POLL_INTERVAL_SECONDS=60                 # How often (seconds) the DLQ worker runs
DLQ_MAX_RETRIES=3                            # Max retry attempts before alerting
DLQ_ALERT_WEBHOOK_URL=                       # Optional URL to POST DLQ alerts

# ── Finality Poller Intervals (seconds) ────────────────────
FINALITY_POLL_INTERVAL_ARBITRUM=5
FINALITY_POLL_INTERVAL_BASE=10
FINALITY_POLL_INTERVAL_ETHEREUM=30
