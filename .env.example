# TripWire Configuration
APP_ENV=development
APP_PORT=3402

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Convoy (Webhook Delivery)
CONVOY_API_KEY=your_convoy_api_key
CONVOY_URL=http://localhost:5005
WEBHOOK_SIGNING_SECRET=your_signing_secret

# Goldsky
GOLDSKY_API_KEY=your_goldsky_api_key
GOLDSKY_PROJECT_ID=your_project_id
GOLDSKY_WEBHOOK_SECRET=

# Blockchain RPC (for finality checks via httpx)
BASE_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Blockchain RPC addresses, USDC contracts, and ERC-8004 registry
# addresses are set in tripwire/config/settings.py with sensible defaults
