{
  "uid": "tripwire-overview",
  "title": "TripWire Overview",
  "description": "x402 Execution Middleware -- operational dashboard",
  "tags": ["tripwire", "webhooks", "x402"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "chain_id",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(tripwire_events_processed_total, chain_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Event Throughput (events/min)",
      "description": "Rate of processed events per minute, grouped by chain",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto",
            "axisLabel": "events/min",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_events_processed_total{chain_id=~\"$chain_id\"}[1m])) by (chain_id) * 60",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Webhook Success Rate",
      "description": "Percentage of webhooks delivered successfully over the last 5 minutes",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 5, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_webhooks_sent_total{status=\"success\"}[5m])) / sum(rate(tripwire_webhooks_sent_total[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Build Info",
      "description": "Current running version and environment",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 7, "x": 17, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Running", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      },
      "targets": [
        {
          "expr": "tripwire_build_info",
          "legendFormat": "v{{version}} ({{env}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pipeline Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "id": 10
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pipeline Latency by Stage (P50 / P95 / P99)",
      "description": "End-to-end pipeline duration histogram quantiles, broken down by stage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(tripwire_pipeline_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P50 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tripwire_pipeline_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P95 {{stage}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(tripwire_pipeline_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P99 {{stage}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Request Latency (P50 / P95 / P99)",
      "description": "Request duration quantiles by method and path",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(tripwire_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50 overall",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tripwire_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 overall",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(tripwire_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 overall",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Delivery",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "id": 20
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Webhook Delivery Rate",
      "description": "Webhooks sent per second, split by status and delivery mode",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*fail.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_webhooks_sent_total[5m])) by (status, mode)",
          "legendFormat": "{{status}} ({{mode}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "DLQ Backlog",
      "description": "Number of failed deliveries queued for retry in the Dead Letter Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "tripwire_dlq_backlog",
          "legendFormat": "DLQ",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Webhook Delivery Latency (P95)",
      "description": "95th percentile of webhook delivery duration over time",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tripwire_webhook_delivery_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 delivery latency",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Auth & Security",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "id": 30
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Auth Request Rate",
      "description": "Authentication requests per second, grouped by result (success/failure)",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*fail.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*success.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_auth_requests_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Nonce Dedup Hit Rate",
      "description": "Nonce deduplication outcomes -- hit means a replay was blocked",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hit" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_nonce_dedup_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Error Rate by Type",
      "description": "Application errors per second, broken down by error category",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(tripwire_errors_total[5m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Infrastructure",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false,
      "id": 40
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Supabase DB Connections",
      "description": "Active database connections from Supabase built-in metrics",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "DB connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Supabase DB Size",
      "description": "Total database size reported by Supabase metrics endpoint",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "legendFormat": "DB size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "WebSocket Connections",
      "description": "Active WebSocket subscriber connections to blockchain RPC nodes",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "tripwire_ws_connections_active",
          "legendFormat": "WS connections",
          "refId": "A"
        }
      ]
    }
  ]
}
